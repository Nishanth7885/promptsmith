# =====================================================================
#  Prompt Smith — environment variables
# =====================================================================
#
#  Copy this file to .env.local for development:
#      cp .env.example .env.local
#
#  In production, set these in /etc/promptsmith.env (loaded by the
#  systemd unit). Never commit a real .env to git.
# =====================================================================


# ---------- Public app URL ----------
# Used for OAuth callbacks, Cashfree return_url + notify_url, email links.
# Must be reachable from the public internet (use ngrok for local webhook test).
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ---------- Database ----------
# Absolute path to the SQLite file. On the VPS, put this OUTSIDE the deploy
# directory so deploys don't wipe user data.
DATABASE_URL=file:./data/promptsmith.db
# DATABASE_URL=file:/var/lib/promptsmith/promptsmith.db


# ---------- Auth.js (NextAuth v5) ----------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${NEXT_PUBLIC_APP_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=


# ---------- Resend (transactional email) ----------
# API key from https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender domain — must match a domain you've verified in Resend.
EMAIL_FROM="Prompt Smith <hello@promptsmith.ink>"


# ---------- Cashfree (server-only — never prefix with NEXT_PUBLIC_) ----------
# Get keys from https://merchant.cashfree.com -> Developers -> API Keys.
# Use sandbox keys for local dev. Production keys go in /etc/promptsmith.env
# on the VM, never in this file or in git.
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
# 'sandbox' or 'production'
CASHFREE_MODE=sandbox


# ---------- Pricing defaults ----------
# These seed the settings table on first run. After that, edit them in /admin.
DEFAULT_PRICE_INR=249
DEFAULT_PRICE_USD=2.99


# ---------- Admin bootstrap ----------
# Email of the first admin user. On first signup with this email, the user
# gets role='admin'. Leave blank to disable.
ADMIN_BOOTSTRAP_EMAIL=


# ---------- Grant token signing (legacy fallback for localStorage unlock) ----------
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PROMPTSMITH_GRANT_SECRET=
